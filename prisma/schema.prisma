generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  EARNING
  ACTIVATION
  GAME_WIN
  GAME_LOSS
  GAME_DEPOSIT
}

enum TxStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum GameType {
  T2000
  T5000
  T10000
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum PaymentType {
  MOBILE_MONEY
  BANK
  CRYPTO
  OTHER
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  username           String    @unique
  passwordHash       String
  phone              String?
  country            String    @default("US")
  language           String    @default("en")
  role               Role      @default(USER)
  isActive           Boolean   @default(false)
  isActivated        Boolean   @default(false)
  isEmailVerified    Boolean   @default(false)
  isSuspended        Boolean   @default(false)
  mainBalance        Decimal   @default(0) @db.Decimal(10,2)
  gameBalance        Decimal   @default(0) @db.Decimal(10,2)
  emailVerifyToken   String?
  emailVerifyExpiry  DateTime?
  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  transactions       ProtocolTransaction[]
  quizAttempts       QuizAttempt[]
  videoWatches       VideoWatch[]
  gamePlays          GamePlay[]
  notifications      Notification[]
  ticketsCreated     SupportTicket[]
  messages           SupportMessage[]
}

model ProtocolTransaction {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             TxType
  amount           Decimal   @db.Decimal(10,2)
  currency         String    @default("USD")
  localAmount      Decimal?  @db.Decimal(10,2)
  status           TxStatus  @default(PENDING)
  paymentMethod    String?
  paymentReference String?
  proofImage       String?
  notes            String?
  approvedBy       String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@index([userId])
  @@index([status])
}


model Quiz {
  id          String        @id @default(uuid())
  title       String
  description String?
  reward      Decimal       @default(0.20) @db.Decimal(10,2)
  timeLimit   Int           @default(10)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  questions   QuizQuestion[]
  attempts    QuizAttempt[]
}

model QuizQuestion {
  id           String  @id @default(uuid())
  quizId       String
  quiz         Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question     String
  options      Json
  correctIndex Int
  order        Int
  @@index([quizId])
}

model QuizAttempt {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score         Int
  passed        Boolean
  earnedAmount  Decimal  @default(0) @db.Decimal(10,2)
  scheduledDate DateTime @db.Date
  completedAt   DateTime @default(now())
  @@unique([userId, quizId, scheduledDate])
  @@index([userId, scheduledDate])
}

model Video {
  id          String       @id @default(uuid())
  title       String
  description String?
  url         String
  thumbnailUrl String?
  reward          Decimal      @default(0.20) @db.Decimal(10,2)
  duration        Int
  verificationCode String?
  isNewUserVideo  Boolean      @default(false)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  watches     VideoWatch[]
}

model VideoWatch {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId       String
  video         Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  earnedAmount  Decimal  @default(0) @db.Decimal(10,2)
  scheduledDate DateTime @db.Date
  watchedAt     DateTime @default(now())
  @@unique([userId, videoId, scheduledDate])
  @@index([userId, scheduledDate])
}

model DailySchedule {
  id                    String   @id @default(uuid())
  date                  DateTime @unique @db.Date
  quizIds               Json     // Array of quiz IDs
  videoIds              Json     // Array of video IDs
  // Daily winning numbers for games
  t2000WinningNumbers   Json    @default("[7, 77, 777]")
  t5000WinningNumbers   Json    @default("[8, 88, 888]")
  t10000WinningNumbers  Json    @default("[9, 99, 999]")
  createdAt             DateTime @default(now())
}

model GameConfig {
  id                    String   @id @default("singleton")
  t2000DailyLimit       Int      @default(3)
  t5000DailyLimit       Int      @default(3)
  t10000DailyLimit      Int      @default(3)
  t2000NumberPool       Json     @default("[7, 77, 777]")
  t5000NumberPool       Json     @default("[8, 88, 888]")
  t10000NumberPool      Json     @default("[9, 99, 999]")
  updatedAt             DateTime @updatedAt
}

model GamePlay {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType    GameType
  tokenPicked String
  winToken    String
  winNumbers  Json?
  didWin      Boolean
  amount      Decimal   @db.Decimal(10,2)
  winnings    Decimal   @default(0) @db.Decimal(10,2)
  createdAt   DateTime  @default(now())
  @@index([userId])
  @@index([userId, gameType, createdAt])
}


model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([userId, isRead])
}

model SupportTicket {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  status    TicketStatus   @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  SupportMessage[]
}

model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime      @default(now())
  @@index([ticketId])
}

model PaymentMethod {
  id           String      @id @default(uuid())
  name         String
  type         PaymentType
  instructions String?
  isActive     Boolean     @default(true)
  country      String?
  createdAt    DateTime    @default(now())
}
